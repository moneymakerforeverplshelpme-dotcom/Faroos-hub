-- AIMBOT TEST LOGIC (Field of View / Target Check)
local function GetClosest()
    local target, dist = nil, 200 -- 200 Stud Range
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= P and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local pos, vis = C:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(C.ViewportSize.X/2, C.ViewportSize.Y/2)).Magnitude
            if vis and mag < dist then dist = mag target = v.Character.HumanoidRootPart end
        end
    end
    return target
end

